{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "components/core/**",
              "ui_kits/healthpath/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AssistantMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:thinking|children|key|ref|className|style|children)$/]",
        "message": "<AssistantMessage> doesn't accept that prop. Declared props: thinking, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|initials|size|brand|className|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, initials, size, brand, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|brand|info|warn|solid)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'brand' | 'info' | 'warn' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|showWord|href|key|ref|className|style|children)$/]",
        "message": "<BrandLogo> doesn't accept that prop. Declared props: size, showWord, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandLogo'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<BrandLogo> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|leftIcon|rightIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, leftIcon, rightIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Composer'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onSend|onAttach|onMicToggle|isRecording|placeholder|disabled|disclaimer|autoFocus|key|ref|className|style|children)$/]",
        "message": "<Composer> doesn't accept that prop. Declared props: value, onChange, onSend, onAttach, onMicToggle, isRecording, placeholder, disabled, disclaimer, autoFocus."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConversationItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|meta|status|active|onClick|key|ref|className|style|children)$/]",
        "message": "<ConversationItem> doesn't accept that prop. Declared props: title, meta, status, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConversationItem'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|waiting)$/]",
        "message": "<ConversationItem> status must be one of 'open' | 'waiting'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Disclaimer'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|showIcon|className|key|ref|className|style|children)$/]",
        "message": "<Disclaimer> doesn't accept that prop. Declared props: text, showIcon, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocumentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|caseId|language|status|preview|onDownload|onCopy|onOpen|key|ref|className|style|children)$/]",
        "message": "<DocumentCard> doesn't accept that prop. Declared props: title, caseId, language, status, preview, onDownload, onCopy, onOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='EscalationAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|onClick|key|ref|className|style|children)$/]",
        "message": "<EscalationAction> doesn't accept that prop. Declared props: label, icon, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|size|variant|round|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, children, size, variant, round."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|brand)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:leftIcon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: leftIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarCase'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|meta|status|bucket|key|ref|className|style|children)$/]",
        "message": "<SidebarCase> doesn't accept that prop. Declared props: id, title, meta, status, bucket."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarCase'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|waiting)$/]",
        "message": "<SidebarCase> status must be one of 'open' | 'waiting'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarCase'] > JSXAttribute[name.name='bucket'] > Literal[value!=/^(?:open|recent|earlier)$/]",
        "message": "<SidebarCase> bucket must be one of 'open' | 'recent' | 'earlier'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UserBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|attachments|key|ref|className|style|children)$/]",
        "message": "<UserBubble> doesn't accept that prop. Declared props: children, attachments."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
